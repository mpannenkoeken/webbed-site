---
layout: page
pagination:
  data: collections
  size: 1
  alias: category

permalink: /categories/{{ category | slug }}/
hide_from_sitemap: true
---

<ul class="category-{{ category }} leading-loose">
{% for post in collections.projects%}
  {% if category in post.data.tags %}
    <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
  {% endif %}
{% endfor %}
{% for post in collections.blog%}
  {% if category in post.data.tags %}
    <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
  {% endif %}
{% endfor %}
</ul>

<p class="text-400">Back to <a href="/categories/">all categories</a></p>
