{
  "name": "skeleventy",
  "version": "3.0.0",
  "description": "Skeleventy gives you a rock solid foundation to build fast and accessible static websites",
  "scripts": {
    "dev": "ELEVENTY_ENV=development npx @11ty/eleventy --config=eleventy.config.js --serve --quiet & npm run sass:watch",
    "production": "mix --production & npx @11ty/eleventy --config=eleventy.config.js",
	"sass:watch": "sass resources/scss:css --watch",
	"build": "sass resources/scss:css --style=compressed && npx @11ty/eleventy"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "Joe Dyer",
  "license": "",
  "devDependencies": {
    "@11ty/eleventy": "^0.11.1",
    "@11ty/eleventy-navigation": "^0.1.6",
    "gorko": "^0.2.3",
    "html-minifier": "^4.0.0",
    "postcss": "^8.2.6",
    "sass": "^1.101.0",
    "webpack": "^5.108.0",
    "webpack-cli": "^4.10.0"
  }
}
